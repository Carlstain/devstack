def teardown_project(name, entry):
    heading(f"Stopping '{name}'")
    rows = []
    services = entry["services"]
    session = tmux_session_name(name)

    if not sys.stdout.isatty():
        # Non-tty keeps the pre-dynamic behavior exactly: static table once,
        # docker compose's own output streaming straight through, plain ok()
        # lines. Mirrors cmd_run's animate split.
        rows = []
        for svc in services:
            detail = svc.get("compose_project") or svc.get("script") or svc.get("command", "") or "-"
            rows.append([svc["name"], svc["runner"], detail])
        print(render_table(["service", "runner", "detail"], rows))
        for svc in reversed(services):
            if svc["runner"] == "docker-compose":
                print(f"  stopping {paint(svc['name'], C.BOLD)}...")
                subprocess.run(["docker", "compose", "-p", svc["compose_project"], "down"])
        if shutil.which("tmux") and tmux_has_session(session):
            subprocess.run(["tmux", "kill-session", "-t", session], check=True)
            ok(f"killed tmux session '{session}'")
        return

    # tty: same treatment as the run view - ONE table (StopTable), rendered
    # once with real service_running() statuses, updated in place. Compose's
    # own output is captured (Popen+PIPE) rather than streamed: any
    # subprocess writing to stdout mid-frame would land inside the _Frame
    # region and corrupt the next redraw, so it's swallowed on success (the
    # table already says stopped) and printed *after* the frame is finalized
    # on failure. Docker teardown still runs in REVERSE boot order
    # (deliberate - dependents come down before their dependencies); the
    # table's display rows stay in boot order.
    table = StopTable(services)
    table.draw()
    failures = []  # (svc_name, captured compose output)

    compose_services = [s for s in reversed(services) if s["runner"] == "docker-compose"]
    total = len(compose_services)
    for i, svc in enumerate(compose_services):
        svc_name = svc["name"]
        proc = subprocess.Popen(
            ["docker", "compose", "-p", svc["compose_project"], "down"],
            stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True,
        )
        start = time.time()
        frame_i = 0
        while proc.poll() is None:
            spinner = _SPINNER_FRAMES[frame_i % len(_SPINNER_FRAMES)]
            frame_i += 1
            elapsed = int(time.time() - start)
            table.set_status(svc_name, (f"{spinner} stopping ({elapsed}s)", C.YELLOW), animate=False)
            table.set_context(dim(f"{spinner} stopping {svc_name} ({i + 1}/{total})"), animate=True)
            time.sleep(0.25)
        output = proc.stdout.read() if proc.stdout else ""
        if proc.returncode == 0:
            table.set_status(svc_name, ("○ stopped", C.DIM), animate=True)
        else:
            table.set_status(svc_name, ("✗ error", C.RED), animate=True)
            failures.append((svc_name, output))

    killed = False
    if shutil.which("tmux") and tmux_has_session(session):
        subprocess.run(["tmux", "kill-session", "-t", session], check=True, capture_output=True)
        killed = True
    # Non-docker services die with the tmux session's panes (or were never
    # tracked at all if there's no session) - flip them to stopped either way.
    for svc in services:
        if svc["runner"] != "docker-compose":
            table.set_status(svc["name"], ("○ stopped", C.DIM), animate=False)
    final_context = dim(f"killed tmux session '{session}'") if killed else None
    table.set_context(final_context, animate=True)

    # Only now, with the frame finalized (nothing redraws above this point),
    # is it safe to print captured compose output for any failures.
    for svc_name, output in failures:
        err(f"docker compose down failed for {svc_name}:")
        if output:
            sys.stdout.write(output if output.endswith("\n") else output + "\n")


def check_other_running(registry, name):
    others = running_projects(registry, exclude=name)
    if not others:
        return

    heading("Another project looks like it's already running")
    rows = []
    for o in others:
        live = [s["name"] for s in registry[o]["services"] if service_running(s)]
        status = (", ".join(live), C.GREEN) if live else ("(docker only)", C.DIM)
        rows.append([o, status])
    print(render_table(["project", "running services"], rows))

    if not sys.stdin.isatty():
        warn("non-interactive - leaving it running and continuing")
        return

    label = others[0] if len(others) == 1 else "them"
    choice = ask_choice(
        "what do you want to do?",
        [f"Stop {label} and continue", "Keep it running and start this too", "Cancel"],
    )
    if choice == "Cancel":
        print("cancelled")
        sys.exit(0)
    if choice.startswith("Stop"):
        for o in others:
            teardown_project(o, registry[o])


def run_tmux(name, entry, table, animate):
    # Reports progress through `table` (a StatusTable) instead of printing
    # its own "── Starting X ──" headings / ok()/err() lines - cmd_run owns
    # the single dynamic table those used to be scattered across. `animate`
    # mirrors cmd_run's tty check: when False, status changes only update
    # table's internal state (no redraw), and the ok()/err() lines below are
    # the non-tty fallback text (see CLAUDE.md).
    services = entry["services"]
    session = tmux_session_name(name)
    if tmux_has_session(session):
        for svc in services:
            status = ("● running", C.GREEN) if service_running(svc) else ("○ stopped", C.DIM)
            table.set_status(svc["name"], status, animate=False)
        if not animate:
            ok(f"session '{session}' already running")
        return

    total = len(services)
    for i, svc in enumerate(services):
        svc_name = svc["name"]
        table.set_status(svc_name, (f"{_SPINNER_FRAMES[0]} starting (0s)", C.YELLOW), animate=animate)
        table.set_context(
            dim(f"{_SPINNER_FRAMES[0]} starting {svc_name} ({i + 1}/{total})"), animate=animate
        )
        cmd = build_pane_command(svc)
        if i == 0:
            subprocess.run(
                ["tmux", "new-session", "-d", "-s", session, "-n", "main", cmd],
                check=True,
            )
        else:
            subprocess.run(["tmux", "split-window", "-t", session, cmd], check=True)
        if svc.get("port"):
            def tick(spinner, elapsed, svc_name=svc_name, i=i):
                table.set_status(svc_name, (f"{spinner} starting ({int(elapsed)}s)", C.YELLOW), animate=True)
                table.set_context(
                    dim(f"{spinner} starting {svc_name} ({i + 1}/{total})"), animate=True
                )
            up = wait_for_port(svc["port"], tick=tick if animate else None)
            if up:
                table.set_status(svc_name, ("● running", C.GREEN), animate=animate)
                if not animate:
                    ok(f"{svc_name} is up on :{svc['port']}")
            else:
                table.set_status(svc_name, ("✗ timeout", C.RED), animate=animate)
                if not animate:
                    err(f"timed out waiting for {svc_name} on :{svc['port']}")
        else:
            table.set_status(svc_name, ("● started", C.GREEN), animate=animate)
    subprocess.run(["tmux", "select-layout", "-t", session, "tiled"], check=True)


def _configobj_value(value):
    # ConfigObj (terminator's config format) needs triple-quoting for values
    # with spaces/quotes/#, or that are empty - everything else can be bare.
    value = str(value)
    if value == "" or re.search(r'''[\s"'#]''', value):
        return f"'''{value}'''"
    return value


def _terminator_layout(services):
    # Grid layout: at most 2 terminals per row, rows stacked top-to-bottom,
    # boot order mapping left-to-right then top-to-bottom. Schema
    # reverse-engineered from the installed terminatorlib source (config.py
    # DEFAULTS['layouts'], terminal.py describe_layout/create_layout,
    # paned.py create_layout) since it isn't documented: a Paned widget
    # (HPaned/VPaned) always has exactly 2 children, distinguished by their
    # own 'order' field (0 = left/top, 1 = right/bottom) relative to that
    # shared parent - so a full row of 2 is one HPaned, and rows are chained
    # together vertically through nested VPaneds (the same "chain through
    # a single parent" trick the old side-by-side-only version used, just
    # one level up: chaining rows instead of chaining terminals directly).
    # Shapes this produces: N=1 -> single Terminal. N=2 -> one HPaned(t0,t1).
    # N=3 -> VPaned(HPaned(t0,t1), t2). N=4 -> VPaned(HPaned(t0,t1),
    # HPaned(t2,t3)). N=5 -> VPaned(HPaned(t0,t1), VPaned(HPaned(t2,t3), t4)).
    layout = {"window0": {"type": "Window", "parent": ""}}
    n = len(services)
    if n == 1:
        layout["terminal0"] = {
            "type": "Terminal", "parent": "window0", "order": 0,
            "profile": "default", "command": build_pane_command(services[0]),
        }
        return layout

    def add_terminal(index, parent, order):
        layout[f"terminal{index}"] = {
            "type": "Terminal", "parent": parent, "order": order,
            "profile": "default", "command": build_pane_command(services[index]),
        }

    def build_row(indices, parent, order, row_num):
        # A row of 1 (only possible for the trailing row on odd N) attaches
        # its lone terminal directly; a row of 2 becomes its own HPaned.
        if len(indices) == 1:
            add_terminal(indices[0], parent, order)
            return
        hpaned_id = f"hpaned{row_num}"
        layout[hpaned_id] = {"type": "HPaned", "parent": parent, "order": order}
        add_terminal(indices[0], hpaned_id, 0)
        add_terminal(indices[1], hpaned_id, 1)

    rows = [list(range(i, min(i + 2, n))) for i in range(0, n, 2)]
    if len(rows) == 1:
        build_row(rows[0], "window0", 0, 0)
        return layout

    parent = "window0"
    for row_num, row in enumerate(rows[:-1]):
        vpaned_id = f"vpaned{row_num}"
        layout[vpaned_id] = {"type": "VPaned", "parent": parent, "order": 1}
        build_row(row, vpaned_id, 0, row_num)
        parent = vpaned_id
    build_row(rows[-1], parent, 1, len(rows) - 1)
    return layout


def run_terminator(name, entry, table, animate):
    # Same table-reporting contract as run_tmux above. Terminator has no
    # per-pane launch step to straddle (the whole layout opens in one Popen
    # call), so the per-service loop below is purely the port-polling
    # sequence - but it still walks services in boot order and marks each
    # "starting" before polling, so the table reads the same progression.
    services = entry["services"]
    if services and all(service_running(s) for s in services):
        for svc in services:
            table.set_status(svc["name"], ("● running", C.GREEN), animate=False)
        if not animate:
            ok(f"'{name}' looks like it's already running")
        return

    layout_name = f"sspinner-{name}"
    layout = _terminator_layout(services)
    lines = ["[profiles]", "[[default]]", "[layouts]", f"[[{layout_name}]]"]
    for obj_id, fields in layout.items():
        lines.append(f"[[[{obj_id}]]]")
        for key, value in fields.items():
            lines.append(f"{key} = {_configobj_value(value)}")

    with tempfile.NamedTemporaryFile("w", suffix=".config", delete=False) as tf:
        tf.write("\n".join(lines) + "\n")
        config_path = tf.name

    subprocess.Popen([
        "terminator", "-u", "-g", config_path, "-l", layout_name,
        "-T", f"sspinner: {name}",
    ])

    total = len(services)
    for i, svc in enumerate(services):
        svc_name = svc["name"]
        table.set_status(svc_name, (f"{_SPINNER_FRAMES[0]} starting (0s)", C.YELLOW), animate=animate)
        table.set_context(
            dim(f"{_SPINNER_FRAMES[0]} starting {svc_name} ({i + 1}/{total})"), animate=animate
        )
        if svc.get("port"):
            def tick(spinner, elapsed, svc_name=svc_name, i=i):
                table.set_status(svc_name, (f"{spinner} starting ({int(elapsed)}s)", C.YELLOW), animate=True)
                table.set_context(
                    dim(f"{spinner} starting {svc_name} ({i + 1}/{total})"), animate=True
                )
            up = wait_for_port(svc["port"], tick=tick if animate else None)
            if up:
                table.set_status(svc_name, ("● running", C.GREEN), animate=animate)
                if not animate:
                    ok(f"{svc_name} is up on :{svc['port']}")
            else:
                table.set_status(svc_name, ("✗ timeout", C.RED), animate=animate)
                if not animate:
                    err(f"timed out waiting for {svc_name} on :{svc['port']}")
        else:
            table.set_status(svc_name, ("● started", C.GREEN), animate=animate)


def run_fallback(name, entry, background=False):
    # background=True (run -b when tmux isn't available either) skips the
    # exec-last-service-into-the-foreground special case below - every
    # service gets the same Popen+logfile treatment and control returns to
    # the shell. Those Popen'd processes are fire-and-forget: sspinner keeps
    # no pid file, so `stop` can't kill non-docker services started this way
    # (see CLAUDE.md's "run control flow" for the honest limitation note).
    warn("neither terminator nor tmux found - running services sequentially, no split panes.")
    services = entry["services"]
    for i, svc in enumerate(services):
        is_last = i == len(services) - 1
        cmd = build_pane_command(svc)
        heading(f"Starting {svc['name']}")
        if not background and is_last and svc["runner"] != "docker-compose":
            print(dim(f"    {cmd}"))
            os.execvp("bash", ["bash", "-c", cmd])
            return  # unreachable
        log_path = Path(tempfile.gettempdir()) / f"sspinner-{name}-{svc['name']}.log"
        logf = open(log_path, "w")
        subprocess.Popen(["bash", "-c", cmd], stdout=logf, stderr=subprocess.STDOUT)
        print(dim(f"    logging to {log_path}"))
        if svc.get("port"):
            if wait_for_port(svc["port"], label=svc["name"]):
                ok(f"{svc['name']} is up on :{svc['port']}")
            else:
                err(f"timed out waiting for {svc['name']} on :{svc['port']}")
    print(f"\nAll services started in background. Logs: {DOZZLE_URL}")


def cmd_run(args):
    registry = load_registry()
    entry = registry.get(args.name)
    if entry is None:
        err(f"'{args.name}' isn't registered. Run 'sspinner register {args.name}' first.")
        sys.exit(1)

    check_other_running(registry, args.name)

    infra_up()
    if entry.get("network"):
        ensure_network(entry["network"])

    services = entry["services"]

    heading(f"Starting '{args.name}'")

    # -b/--background changes the backend priority: terminator is skipped
    # entirely (a GUI window is inherently foreground - the whole point of
    # the flag is to not open one), so it's tmux (detached, no attach at the
    # end) or the fallback in background mode.
    background = getattr(args, "background", False)
    if background:
        backend = "tmux" if shutil.which("tmux") else None
    else:
        backend = "terminator" if shutil.which("terminator") else (
            "tmux" if shutil.which("tmux") else None
        )
    if backend is None:
        # run_fallback is deliberately thin (CLAUDE.md) - it keeps its own
        # sequential prints and label-based spinner rather than going
        # through StatusTable, since there are no panes/session for a
        # dynamic table to describe here anyway.
        run_fallback(args.name, entry, background=background)
        return

    # ONE table for the whole boot, rendered once up front and then updated
    # in place as each service starts (tty) - or printed once now and once
    # more at the end, with plain ok()/err() lines in between (non-tty). See
    # CLAUDE.md's "run control flow".
    animate = sys.stdout.isatty()
    table = StatusTable(services)
    if animate:
        table.draw()
    else:
        table.print_once()

    if backend == "terminator":
        run_terminator(args.name, entry, table, animate)
    else:
        run_tmux(args.name, entry, table, animate)

    if backend == "tmux":
        session = tmux_session_name(args.name)
        if background:
            pointer = (
                f"tmux session: {session} "
                f"(detached — attach with: tmux attach -t {session})"
            )
        else:
            pointer = f"tmux session: {session}"
    else:
        pointer = f"terminator window: sspinner: {args.name}"

    if animate:
        table.set_context(dim(pointer), animate=True)
    else:
        table.print_once()
        print(pointer)
    print(dim(f"logs: {DOZZLE_URL}"))

    if backend == "tmux" and not background:
        session = tmux_session_name(args.name)
        if sys.stdout.isatty():
            os.execvp("tmux", ["tmux", "attach", "-t", session])
        else:
            print(f"Attach with: tmux attach -t {session}")


def cmd_stop(args):
    registry = load_registry()
    entry = registry.get(args.name)
    if entry is None:
        err(f"'{args.name}' isn't registered. Run 'sspinner list' to see what is.")
        sys.exit(1)

    teardown_project(args.name, entry)


def cmd_down(args):
    # Deprecated alias for 'stop' - kept working (hidden from --help and
    # COMMANDS_HELP via argparse.SUPPRESS) so muscle memory and old scripts
    # don't break, but nudges toward the new name. 'infra down' is untouched:
    # that's compose terminology in a different namespace.
    print(dim("'down' is now 'stop'"))
    cmd_stop(args)


COMMANDS_HELP = [
    ("register <name>", "interactively define a project's services"),
    ("edit <name>", "open a project's config in $EDITOR"),
    ("list", "show registered projects and live status"),
    ("run <name> [-b]", "boot a registered project's stack (-b: background, no attach/window)"),
    ("stop <name>", "tear down a project's stack"),
    ("infra up|down", "manage the shared Dozzle log viewer"),
]


def print_help():
    print(paint("sspinner", C.BOLD, C.CYAN) +
          " — global launcher for multi-repo dev stacks")
    heading("USAGE")
    print("  sspinner <command> [args]")
    heading("COMMANDS")
    width = max(len(cmd) for cmd, _ in COMMANDS_HELP)
    for cmd, desc in COMMANDS_HELP:
        cmd_col = paint(f"{cmd:<{width}}", C.BOLD, C.CYAN)
        print(f"  {cmd_col}  {dim(desc)}")
    heading("EXAMPLES")
    examples = (
        "sspinner register lawial",
        "sspinner run lawial",
        "sspinner run lawial -b   # background: no window, no attach",
        "sspinner stop lawial",
        "sspinner list",
    )
    for line in examples:
        print(dim(f"  {line}"))
    print(f"\n{dim('logs:')} {DOZZLE_URL}")


def build_parser():
    parser = argparse.ArgumentParser(prog="sspinner", description=__doc__)
    sub = parser.add_subparsers(dest="command", required=True)

    p = sub.add_parser("register", help="interactively define a project's services")
    p.add_argument("name", help="project name")
    p.set_defaults(func=cmd_register)

    p = sub.add_parser("edit", help="open a project's config in $EDITOR")
    p.add_argument("name", help="project name")
    p.set_defaults(func=cmd_edit)

    p = sub.add_parser("list", help="show registered projects and live status")
    p.set_defaults(func=cmd_list)

    p = sub.add_parser("run", help="boot a registered project's stack")
    p.add_argument("name", help="project name")
    p.add_argument(
        "-b", "--background", action="store_true",
        help="boot detached: no GUI window, no tmux attach (tmux or fallback only)",
    )
    p.set_defaults(func=cmd_run)

    p = sub.add_parser("stop", help="tear down a registered project's stack")
    p.add_argument("name", help="project name")
    p.set_defaults(func=cmd_stop)

    # deprecated alias for 'stop' - hidden from help, still functional
    p = sub.add_parser("down", help=argparse.SUPPRESS)
    p.add_argument("name", help="project name")
    p.set_defaults(func=cmd_down)

    infra = sub.add_parser("infra", help="manage the shared Dozzle log viewer")
    infra_sub = infra.add_subparsers(dest="infra_command", required=True)
    p = infra_sub.add_parser("up", help="start Dozzle")
    p.set_defaults(func=cmd_infra_up)
    p = infra_sub.add_parser("down", help="stop Dozzle")
    p.set_defaults(func=cmd_infra_down)

    p = sub.add_parser("_names", help=argparse.SUPPRESS)
    p.set_defaults(func=cmd_names)

    return parser


def main():
    if len(sys.argv) == 1 or sys.argv[1] in ("-h", "--help"):
        print_help()
        return
    args = build_parser().parse_args()
    args.func(args)


if __name__ == "__main__":
    main()

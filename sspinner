COMPOSE_FILENAMES = ("docker-compose.yml", "docker-compose.yaml", "compose.yml", "compose.yaml")


def _detect_runner(path):
    p = Path(path)
    if any((p / f).exists() for f in COMPOSE_FILENAMES):
        return "docker-compose"
    if (p / "package.json").exists():
        if (p / "pnpm-lock.yaml").exists():
            return "pnpm"
        if (p / "yarn.lock").exists():
            return "yarn"
        return "npm"
    if (p / "pyproject.toml").exists():
        return "poetry"
    return None


def _package_json_scripts(path):
    pkg = Path(path) / "package.json"
    if not pkg.exists():
        return {}
    try:
        data = json.loads(pkg.read_text())
    except (json.JSONDecodeError, OSError):
        return {}
    scripts = data.get("scripts")
    return scripts if isinstance(scripts, dict) else {}


def _detect_port(path):
    p = Path(path)
    for fname in COMPOSE_FILENAMES:
        compose = p / fname
        if compose.exists():
            match = re.search(r'-\s*"?(\d{2,5}):\d{2,5}"?', compose.read_text())
            if match:
                return int(match.group(1))
            break
    pkg = p / "package.json"
    if pkg.exists():
        match = re.search(r'"PORT"\s*:\s*"?(\d{2,5})', pkg.read_text())
        if match:
            return int(match.group(1))
    return None


def configure_runner(runner, path):
    # Every question here is allow_back=True: this is where the "worst case"
    # trap lived (custom's required command prompt, no way out). If ANY
    # answer comes back BACK, propagate it immediately rather than partially
    # filling in the returned dict - register_one_service re-asks the runner
    # choice from scratch on BACK.
    if runner == "docker-compose":
        compose_project = ask("compose project name (-p)", required=True, allow_back=True)
        if compose_project is BACK:
            return BACK
        build = ask_yes_no("build image before starting?", default=True, allow_back=True)
        if build is BACK:
            return BACK
        return {"compose_project": compose_project, "build": build}
    if runner in ("yarn", "pnpm", "npm"):
        scripts = _package_json_scripts(path)
        if scripts:
            default_script = "dev" if "dev" in scripts else next(iter(scripts))
            options = [default_script] + [s for s in scripts if s != default_script]
            script = ask_choice(f"script to run ({runner} run <script>)", options, allow_back=True)
        else:
            script = ask("script to run", default="dev", allow_back=True)
        if script is BACK:
            return BACK
        return {"script": script}
    if runner == "poetry":
        command = ask("command to run after 'poetry run'", required=True, allow_back=True)
        if command is BACK:
            return BACK
        return {"command": command}
    if runner == "custom":
        command = ask("full shell command to run", required=True, allow_back=True)
        if command is BACK:
            return BACK
        return {"command": command}
    raise ValueError(runner)


def register_one_service(project_slug, existing_names):
    heading("New service")
    while True:
        name = ask("name (e.g. back, front, keycloak)", required=True)
        if name not in existing_names:
            break
        print(dim(f"    '{name}' is already used in this project, pick another"))
    path = ask_path("path (directory)")

    detected = _detect_runner(path)
    runner_options = RUNNERS
    if detected and detected in RUNNERS:
        runner_options = [detected] + [r for r in RUNNERS if r != detected]
        print(dim(f"    detected: {detected} (based on files in {path})"))

    # runner ask_choice does NOT get allow_back - there's nothing sensible to
    # back out to before it, so Esc there is simply ignored (stays put).
    # configure_runner's own follow-up questions do get allow_back; if the
    # user backs out of one of those, loop back and re-ask the runner choice
    # (detection/pre-fills behave the same on re-entry since runner_options
    # was already computed above).
    while True:
        runner = ask_choice("how is it run?", runner_options)
        extra = configure_runner(runner, path)
        if extra is not BACK:
            break

    default_port = _detect_port(path)
    if default_port:
        print(dim(f"    detected port: {default_port}"))
    port = ask_optional_int(
        "port to wait on before starting the next service (blank = none)",
        default=default_port,
    )
    svc = {"name": name, "path": path, "runner": runner, "port": port}
    svc.update(extra)
    if runner == "docker-compose" and not svc.get("compose_project"):
        svc["compose_project"] = f"{project_slug}-{name}"
    return svc


def print_service_summary(services):
    rows = []
    for i, svc in enumerate(services, 1):
        extra = svc.get("compose_project") or svc.get("script") or svc.get("command", "") or "-"
        port = f":{svc['port']}" if svc.get("port") else "-"
        rows.append([str(i), svc["name"], svc["runner"], port, extra])
    print(render_table(["#", "service", "runner", "port", "detail"], rows))


def _reorder_services(services):
    n = len(services)
    example = ",".join(str(i) for i in range(n, 0, -1))
    while True:
        raw = ask(f"new order, comma-separated 1-{n} (e.g. {example})", required=True)
        try:
            order = [int(x.strip()) for x in raw.split(",")]
        except ValueError:
            print(dim("    not a list of numbers, try again"))
            continue
        if sorted(order) != list(range(1, n + 1)):
            print(dim(f"    must be a permutation of 1-{n}, try again"))
            continue
        reordered = [services[i - 1] for i in order]
        heading("New order")
        print_service_summary(reordered)
        return reordered


def cmd_register(args):
    registry = load_registry()
    existing = registry.get(args.name)
    services = []
    network = None

    if existing:
        heading(f"'{args.name}' is already registered")
        print_service_summary(existing.get("services", []))
        choice = ask_choice(
            "what do you want to do?",
            ["Add more services to it", "Start over (replace everything)", "Cancel"],
        )
        if choice == "Cancel":
            return
        if choice == "Add more services to it":
            services = existing.get("services", [])
            network = existing.get("network")

    if network is None:
        network = ask(
            "shared docker network these services need (blank if none)", default=""
        ) or None

    existing_names = {s["name"] for s in services}
    while True:
        if not ask_yes_no("Add a service?", default=(len(services) == 0)):
            break
        svc = register_one_service(slugify(args.name), existing_names)
        services.append(svc)
        existing_names.add(svc["name"])
        heading("Services so far")
        print_service_summary(services)

    if not services:
        warn("no services added, nothing saved")
        return

    if len(services) > 1 and ask_yes_no("reorder services? (boot order matters)", default=False):
        services = _reorder_services(services)

    heading(f"Final config for '{args.name}'")
    print_service_summary(services)
    if not ask_yes_no("Save this configuration?", default=True):
        warn("not saved")
        return

    registry[args.name] = {"network": network, "services": services}
    save_registry(registry)
    ok(f"saved '{args.name}' ({len(services)} service(s)) -> {REGISTRY_PATH}")


def cmd_edit(args):
    registry = load_registry()
    entry = registry.get(args.name)
    if entry is None:
        err(f"'{args.name}' isn't registered. Run 'sspinner list' to see what is.")
        sys.exit(1)
    editor = shlex.split(os.environ.get("EDITOR", "nano"))
    with tempfile.NamedTemporaryFile("w", suffix=".json", delete=False) as tf:
        json.dump(entry, tf, indent=2)
        tf.write("\n")
        tmp_path = tf.name
    try:
        subprocess.run([*editor, tmp_path], check=True)
        try:
            new_entry = json.loads(Path(tmp_path).read_text())
        except json.JSONDecodeError as e:
            err(f"invalid JSON, not saved: {e}")
            sys.exit(1)
        registry[args.name] = new_entry
        save_registry(registry)
        ok(f"saved changes to '{args.name}'")
    finally:
        os.unlink(tmp_path)



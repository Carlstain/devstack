# ------------------------------------------------------------------ styling
class C:
    RESET = "\033[0m"
    BOLD = "\033[1m"
    DIM = "\033[2m"
    REVERSE = "\033[7m"
    RED = "\033[31m"
    GREEN = "\033[32m"
    YELLOW = "\033[33m"
    BLUE = "\033[34m"
    CYAN = "\033[36m"


def _color_ok():
    return sys.stdout.isatty() and not os.environ.get("NO_COLOR")


def paint(text, *codes):
    if not _color_ok():
        return text
    return "".join(codes) + text + C.RESET


def heading(text):
    # Lightweight section rule, not a box - boxes are reserved for
    # render_table(). Width of the trailing rule is computed off the plain
    # text first (CLAUDE.md styling rule), so it always lands at ~60 cols
    # regardless of how the title is colorized.
    prefix_plain = f"── {text} "
    rule = "─" * max(4, 60 - len(prefix_plain))
    print("\n" + paint(f"── {text}", C.BOLD, C.CYAN) + " " + dim(rule))


def ok(text):
    print(paint("  ✓ ", C.GREEN) + text)


def warn(text):
    print(paint("  ! ", C.YELLOW) + text)


def err(text):
    print(paint("  ✗ ", C.RED) + text, file=sys.stderr)


def dim(text):
    return paint(text, C.DIM)


def render_table(headers, rows):
    # Cells are either a plain string, or a (text, *paint_codes) tuple for a
    # colored cell. Width is always computed off the plain text so painted
    # ANSI codes never throw off column alignment (see CLAUDE.md styling notes).
    def cell_text(cell):
        return cell[0] if isinstance(cell, tuple) else cell

    widths = [len(h) for h in headers]
    for row in rows:
        for i, cell in enumerate(row):
            widths[i] = max(widths[i], len(cell_text(cell)))

    def hline(left, mid, right):
        return left + mid.join("─" * (w + 2) for w in widths) + right

    def render_row(cells, header=False):
        parts = []
        for i, cell in enumerate(cells):
            padded = f"{cell_text(cell):<{widths[i]}}"
            if header:
                parts.append(paint(padded, C.BOLD, C.CYAN))
            elif isinstance(cell, tuple):
                parts.append(paint(padded, *cell[1:]))
            else:
                parts.append(padded)
        return "│ " + " │ ".join(parts) + " │"

    lines = [
        "  " + hline("╭", "┬", "╮"),
        "  " + render_row(headers, header=True),
        "  " + hline("├", "┼", "┤"),
    ]
    for row in rows:
        lines.append("  " + render_row(row))
    lines.append("  " + hline("╰", "┴", "╯"))
    return "\n".join(lines)


# --------------------------------------------------------------- registry
def load_registry():
    if not REGISTRY_PATH.exists():
        return {}
    return json.loads(REGISTRY_PATH.read_text())


def save_registry(data):
    REGISTRY_PATH.parent.mkdir(parents=True, exist_ok=True)
    REGISTRY_PATH.write_text(json.dumps(data, indent=2) + "\n")


def slugify(text):
    return re.sub(r"[^a-z0-9-]+", "-", text.lower()).strip("-")


# ------------------------------------------------------------- interactive
# Every widget below renders inline, in the normal screen buffer - never the
# alternate screen (no \x1b[?1049h/smcup, ever). That switch is what made the
# old alternate-screen picker feel like "a new terminal had opened"; these
# widgets instead draw a small block of lines in place, redraw it in place on
# every keystroke, then collapse it to a single one-line summary when done,
# the same way Claude Code's own prompts feel. Every widget also has a plain
# input()-based fallback used whenever stdin/stdout isn't a real tty, so the
# scripted pipe-driven `register` flow described in CLAUDE.md keeps working
# unchanged - same questions, same order, same accepted answers.
def _interactive():
    return sys.stdin.isatty() and sys.stdout.isatty()


@contextlib.contextmanager
def _raw_mode(hide_cursor=True):
    # cbreak, not full raw: read one keypress at a time but leave signal
    # processing (Ctrl-C) and output post-processing alone. Always restores
    # the original terminal settings on the way out, including when a
    # KeyboardInterrupt unwinds through the 'with' block.
    fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(fd)
    if hide_cursor:
        sys.stdout.write("\x1b[?25l")
        sys.stdout.flush()
    try:
        tty.setcbreak(fd)
        yield
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)
        if hide_cursor:
            sys.stdout.write("\x1b[?25h")
            sys.stdout.flush()


_ARROW_KEYS = {"A": "up", "B": "down", "C": "right", "D": "left"}


def _read_one(fd):
    # Unbuffered single-byte read straight off the fd via os.read(), not
    # sys.stdin.read(). TextIOWrapper's own internal buffering can silently
    # slurp more bytes than requested from the OS on one call, so a later
    # select() on the raw fd sees nothing pending even though a full escape
    # sequence is already sitting in Python's buffer - that mismatch is what
    # breaks arrow-key detection below if sys.stdin.read(1) is used instead.
    return os.read(fd, 1).decode(errors="replace")


def _read_key():
    # Decodes one keypress to a symbolic name where it makes sense (arrow
    # keys, tab, enter, backspace, esc), otherwise returns the raw printable
    # character. A bare Esc and the start of an arrow-key escape sequence
    # both begin with \x1b, so a short select() timeout is used to tell them
    # apart without blocking forever on a lone Esc press.
    fd = sys.stdin.fileno()
    ch = _read_one(fd)
    if ch == "\x03":
        raise KeyboardInterrupt
    if ch == "\x1b":
        ready, _, _ = select.select([fd], [], [], 0.05)
        if not ready:
            return "esc"
        ch2 = _read_one(fd)
        if ch2 != "[":
            return "esc"
        ch3 = _read_one(fd)
        return _ARROW_KEYS.get(ch3, "esc")
    if ch in ("\r", "\n"):
        return "enter"
    if ch == "\t":
        return "tab"
    if ch in ("\x7f", "\x08"):
        return "backspace"
    return ch


def _fit_segments(segments, width=None):
    # segments: [(plain_text, paint_codes_or_None), ...]. Truncation happens
    # on the plain text *before* colorizing (same rule render_table() follows
    # per CLAUDE.md styling notes), and the running width is clamped to the
    # terminal's current column count so a wrapped line can never corrupt the
    # redraw math in _Frame below.
    if width is None:
        width = shutil.get_terminal_size().columns
    out = []
    used = 0
    for text, codes in segments:
        remaining = width - used
        if remaining <= 0:
            break
        if len(text) > remaining:
            text = text[:remaining]
        used += len(text)
        out.append(paint(text, *codes) if codes else text)
    return "".join(out)


class _Frame:
    # Tracks how many lines the widget's previous draw used, so the next
    # draw can move the cursor back up over exactly that many lines
    # (\x1b[<n>A + \r) and erase everything below (\x1b[J) before reprinting,
    # rather than scrolling the screen on every keystroke.
    def __init__(self):
        self.count = 0

    def render(self, lines):
        if self.count:
            sys.stdout.write(f"\x1b[{self.count}A\r\x1b[J")
        sys.stdout.write("\n".join(lines) + "\n")
        sys.stdout.flush()
        self.count = len(lines)

    def collapse(self, summary_line):
        # The signature "finished" move: erase the whole region and leave a
        # single one-line summary behind (green check + dim question +
        # normal-weight answer).
        if self.count:
            sys.stdout.write(f"\x1b[{self.count}A\r\x1b[J")
        sys.stdout.write(summary_line + "\n")
        sys.stdout.flush()
        self.count = 0


def _collapse_line(question, answer):
    return f"{paint('✓', C.GREEN)} {dim(question)} · {answer}"


def ask(prompt, default=None, required=False):
    if not _interactive():
        return _ask_plain(prompt, default=default, required=required)
    width = shutil.get_terminal_size().columns
    hint = f" (default: {default})" if default is not None else ""
    question_line = _fit_segments(
        [("◆ ", (C.CYAN,)), (prompt, (C.BOLD,)), (hint, (C.DIM,))], width
    )
    frame = _Frame()
    error_line = None
    while True:
        lines = [question_line]
        if error_line:
            lines.append(error_line)
        frame.render(lines)
        # Plain input() (cooked mode) is fine here - readline-style editing
        # isn't required, and cooked mode is what lets backspace/line-editing
        # work for free while typing.
        raw = input("  ").strip()
        frame.count += 1  # account for the line input() itself just echoed
        if not raw and default is not None:
            answer = default
            break
        if not raw and required:
            error_line = dim("    required, try again")
            continue
        answer = raw
        break
    frame.collapse(_collapse_line(prompt, answer))
    return answer


def _ask_plain(prompt, default=None, required=False):
    suffix = f" [{default}]" if default is not None else ""
    while True:
        raw = input(paint(f"  {prompt}{suffix}: ", C.BOLD)).strip()
        if not raw and default is not None:
            return default
        if not raw and required:
            print(dim("    required, try again"))
            continue
        return raw


def ask_int(prompt, default=None):
    while True:
        raw = ask(prompt, default=str(default) if default is not None else None)
        try:
            return int(raw)
        except ValueError:
            print(dim("    not a number, try again"))


def ask_optional_int(prompt, default=None):
    raw = ask(prompt, default=str(default) if default is not None else "")
    if not raw:
        return None
    try:
        return int(raw)
    except ValueError:
        print(dim("    not a number, skipping"))
        return None


def ask_yes_no(prompt, default=True):
    if not _interactive():
        return _ask_yes_no_plain(prompt, default)
    width = shutil.get_terminal_size().columns
    selected = default
    frame = _Frame()

    def render_line():
        if selected:
            yes, no = ("❯ Yes", (C.BOLD, C.CYAN)), ("  No", (C.DIM,))
        else:
            yes, no = ("  Yes", (C.DIM,)), ("❯ No", (C.BOLD, C.CYAN))
        return _fit_segments(
            [("◆ ", (C.CYAN,)), (prompt, (C.BOLD,)), ("   ", None), yes, ("    ", None), no],
            width,
        )

    with _raw_mode():
        while True:
            frame.render([render_line()])
            key = _read_key()
            if key in ("left", "right", "tab"):
                selected = not selected
            elif key in ("y", "Y"):
                selected = True
            elif key in ("n", "N"):
                selected = False
            elif key == "enter":
                break
    frame.collapse(_collapse_line(prompt, "Yes" if selected else "No"))
    return selected


def _ask_yes_no_plain(prompt, default=True):
    suffix = "Y/n" if default else "y/N"
    while True:
        raw = input(paint(f"  {prompt} [{suffix}]: ", C.BOLD)).strip().lower()
        if not raw:
            return default
        if raw in ("y", "yes"):
            return True
        if raw in ("n", "no"):
            return False


def ask_choice(prompt, options):
    if not _interactive():
        return _ask_choice_plain(prompt, options)
    width = shutil.get_terminal_size().columns
    question_line = _fit_segments([("◆ ", (C.CYAN,)), (prompt, (C.BOLD,))], width)
    selected = 0
    frame = _Frame()
    with _raw_mode():
        while True:
            lines = [question_line]
            for i, opt in enumerate(options):
                if i == selected:
                    lines.append(_fit_segments([("  ❯ ", (C.CYAN,)), (opt, (C.BOLD,))], width))
                else:
                    lines.append(_fit_segments([(f"    {opt}", (C.DIM,))], width))
            frame.render(lines)
            key = _read_key()
            if key == "up":
                selected = (selected - 1) % len(options)
            elif key == "down":
                selected = (selected + 1) % len(options)
            elif key.isdigit() and key != "0" and int(key) <= len(options):
                selected = int(key) - 1
            elif key == "enter":
                break
    frame.collapse(_collapse_line(prompt, options[selected]))
    return options[selected]


def _ask_choice_plain(prompt, options):
    print(paint(f"  {prompt}", C.BOLD))
    for i, opt in enumerate(options, 1):
        print(f"    {i}) {opt}")
    while True:
        raw = input(paint("  > ", C.BOLD)).strip()
        if raw.isdigit() and 1 <= int(raw) <= len(options):
            return options[int(raw) - 1]
        print(dim(f"    enter a number 1-{len(options)}"))


def _ask_path_plain(prompt, default=None):
    while True:
        raw = ask(prompt, default=default, required=True)
        path = Path(raw).expanduser().resolve()
        if path.is_dir():
            return str(path)
        print(dim(f"    '{path}' isn't a directory, try again"))


def _path_suggestions(buffer, limit=10):
    expanded = os.path.expanduser(buffer) if buffer else str(Path.cwd())
    if not buffer or buffer.endswith("/"):
        base, prefix = expanded, ""
    else:
        base, prefix = os.path.split(expanded)
        base = base or "."
    try:
        entries = sorted(
            p for p in Path(base).iterdir()
            if p.is_dir()
            and p.name.startswith(prefix)
            and (prefix.startswith(".") or not p.name.startswith("."))
        )
    except OSError:
        entries = []
    return base, entries[:limit]


def ask_path(prompt, default=None):
    # Single prompt line with up to 8 suggestion lines below, redrawn on
    # every keystroke - the inline replacement for the old alternate-screen dropdown.
    # Falls back to the plain input()-based picker when there's no real
    # terminal to draw into.
    if not _interactive():
        return _ask_path_plain(prompt, default)

    width = shutil.get_terminal_size().columns
    buffer = default or ""
    highlighted = 0
    error = None
    path = None
    frame = _Frame()

    with _raw_mode():
        while True:
            base, suggestions = _path_suggestions(buffer)
            highlighted = max(0, min(highlighted, len(suggestions) - 1)) if suggestions else 0

            lines = [
                _fit_segments(
                    [("◆ ", (C.CYAN,)), (f"{prompt} ", (C.BOLD,)), (buffer, None)], width
                )
            ]
            if error:
                lines.append(_fit_segments([(f"    {error}", (C.RED,))], width))
                error = None
            for i, suggestion in enumerate(suggestions[:8]):
                text = f"    {suggestion}/"
                if i == highlighted:
                    lines.append(_fit_segments([(text, (C.CYAN, C.REVERSE))], width))
                else:
                    lines.append(_fit_segments([(text, (C.DIM,))], width))
            lines.append(_fit_segments(
                [("    type to filter · ↑↓ select · tab descend · enter confirm", (C.DIM,))],
                width,
            ))
            frame.render(lines)

            key = _read_key()
            if key == "up" and suggestions:
                highlighted = (highlighted - 1) % len(suggestions)
            elif key == "down" and suggestions:
                highlighted = (highlighted + 1) % len(suggestions)
            elif key == "tab" and suggestions:
                buffer = str(suggestions[highlighted]) + "/"
                highlighted = 0
            elif key == "enter":
                candidate = buffer
                expanded_candidate = os.path.expanduser(candidate)
                if not os.path.isdir(expanded_candidate) and suggestions:
                    candidate = str(suggestions[highlighted])
                    expanded_candidate = candidate
                candidate_path = Path(expanded_candidate).resolve()
                if candidate_path.is_dir():
                    path = candidate_path
                    break
                error = f"'{candidate}' isn't a directory, try again"
            elif key == "backspace":
                buffer = buffer[:-1]
                highlighted = 0
            elif key == "esc":
                buffer = ""
                highlighted = 0
            elif len(key) == 1 and key.isprintable():
                buffer += key
                highlighted = 0

    frame.collapse(_collapse_line("path", str(path)))
    return str(path)


# ------------------------------------------------------------- run helpers
_SPINNER_FRAMES = "⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"


def wait_for_port(port, timeout=120, host="localhost", label=None):
    # label=None (or a non-tty stdout) keeps this exactly as silent/plain as
    # before - callers print their own ok()/err() line once this returns.
    # When a label is given on a real terminal, animate a one-line spinner in
    # place (redrawn with \r\x1b[K) so waiting doesn't look like a hang; the
    # line is cleared before returning either way so the caller's line lands
    # clean.
    animate = label is not None and sys.stdout.isatty()
    deadline = time.time() + timeout
    start = time.time()
    frame_i = 0
    while time.time() < deadline:
        try:
            with socket.create_connection((host, port), timeout=2):
                if animate:
                    sys.stdout.write("\r\x1b[K")
                    sys.stdout.flush()
                return True
        except OSError:
            if animate:
                elapsed = int(time.time() - start)
                spinner = _SPINNER_FRAMES[frame_i % len(_SPINNER_FRAMES)]
                frame_i += 1
                text = f"{spinner} waiting for {label} on :{port} ({elapsed}s)"
                sys.stdout.write("\r\x1b[K" + paint(text, C.DIM))
                sys.stdout.flush()
            time.sleep(1)
    if animate:
        sys.stdout.write("\r\x1b[K")
        sys.stdout.flush()
    return False


def is_port_open(port, host="localhost"):
    try:
        with socket.create_connection((host, port), timeout=0.5):
            return True
    except OSError:
        return False


def compose_has_containers(compose_project):
    r = subprocess.run(
        ["docker", "compose", "-p", compose_project, "ps", "-q"],
        capture_output=True, text=True,
    )
    return bool(r.stdout.strip())


def service_running(svc):
    port = svc.get("port")
    if port:
        return is_port_open(port)
    if svc["runner"] == "docker-compose":
        return compose_has_containers(svc["compose_project"])
    return None  # unknown - no port and not docker-compose


def build_pane_command(svc):
    path = svc["path"]
    runner = svc["runner"]
    if runner == "docker-compose":
        build = "--build" if svc.get("build", True) else ""
        project = svc["compose_project"]
        return (
            f'cd "{path}" && docker compose -p "{project}" up -d {build} '
            f'&& docker compose -p "{project}" logs -f --tail 100; exec bash'
        )
    if runner in ("yarn", "pnpm"):
        script = svc.get("script", "dev")
        return f'cd "{path}" && {runner} {script}; exec bash'
    if runner == "npm":
        script = svc.get("script", "dev")
        return f'cd "{path}" && npm run {script}; exec bash'
    if runner == "poetry":
        return f'cd "{path}" && poetry run {svc["command"]}; exec bash'
    if runner == "custom":
        return f'cd "{path}" && {svc["command"]}; exec bash'
    raise ValueError(f"unknown runner {runner!r}")


def ensure_network(name):
    r = subprocess.run(["docker", "network", "inspect", name], capture_output=True)
    if r.returncode != 0:
        ok(f"creating shared docker network '{name}'")
        subprocess.run(["docker", "network", "create", name], check=True)


def tmux_session_name(project):
    return f"devstack-{project}"


def tmux_has_session(session):
    return subprocess.run(
        ["tmux", "has-session", "-t", session], capture_output=True
    ).returncode == 0


